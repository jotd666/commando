* < A0: source (HL)
* < A1: destination (DE)
* < D1: decremented (16 bit)
lddr:
    MAKE_BC_NO_AR
    MAKE_DE_NO_AR
    MAKE_HL_NO_AR
    MAKE_AR_FROM_HL a0
    MAKE_AR_FROM_DE a1
    addq.w  #1,d6
    addq.w  #1,d4
    sub.w   d2,d4
    sub.w   d2,d6
    MAKE_H
    MAKE_D
    subq.w    #1,d2
0:
    move.b    -(a0),-(a1)
    dbf        d2,0b

    subq.w  #1,a1
    subq.w  #1,a0
    moveq	#0,d2
    moveq	#0,d1
    rts

* < A0: source (HL)
* < A1: destination (DE)
* < D1: decremented (16 bit)
ldi:
    MAKE_BC_NO_AR
    MAKE_DE_NO_AR
    MAKE_HL_NO_AR
    MAKE_AR_FROM_HL	a0
    MAKE_AR_FROM_DE	a1
    addq.w    #1,d6
    addq.w    #1,d4
    MAKE_H
    MAKE_D
    move.b    (a0),(a1)
    subq.w    #1,d2
    MAKE_B
    rts

* < A0: source (HL)
* < A1: destination (DE)
* < D1: length (16 bit)
ldir:
    MAKE_BC_NO_AR
    MAKE_HL_NO_AR
    MAKE_DE_NO_AR
    MAKE_AR_FROM_HL	a0
    MAKE_AR_FROM_DE	a1
    add.w	d2,d6
    add.w	d2,d4
    MAKE_H
    MAKE_D
    subq.w    #1,d2
0:
    move.b    (a0)+,(a1)+
    dbf        d2,0b
    moveq	#0,d2
    moveq	#0,d1
    rts

* < all registers d1/d2/d3/d4/d5/d6
* > all registers swapped
*: note regscopy must be defined somewhere in RAM
*: with a size of 48
exx:
    lea     regscopy+24,a0
    * save current regs in region 1
    movem.l d1/d2/d3/d4/d5/d6,-(a0)
    * restore old regs from region 2
    lea     regscopy+24,a0
    movem.l (a0),d1/d2/d3/d4/d5/d6
    * now copy region 1 to region 2
    movem.l d1/d2/d3/d4/d5/d6,-(a7)
    lea     regscopy,a0
    movem.l (a0)+,d1/d2/d3/d4/d5/d6
    movem.l d1/d2/d3/d4/d5/d6,(a0)
    movem.l (a7)+,d1/d2/d3/d4/d5/d6
    rts
