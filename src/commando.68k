mainloop_8000:
	jbsr	osd_disable_interrupts
	jbsr	handle_events_8007                	| [$8001: call handle_events_8007]
	jbsr	osd_enable_interrupts
	* interrupts are only enabled here. vblank will be pending so
	* it will happen if needed, only here (else it causes race conditions
	* like broken scrolling tiles, blocked paths)
	jra	mainloop_8000                      	| [$8004: jp   mainloop_8000]

handle_events_8007:
	GET_ADDRESS	consumed_event_pointer_ed82,a0	| [$8007: ld   hl,(consumed_event_pointer_ed82)]
	move.w	(a0),d6		| even: can read word
	rol.w	#8,d6		| little endian
	MAKE_H
	MAKE_HL	a0                             	| [$800a: ld   a,(hl)]
	move.b	(a0),d0                         	| [...]
	addq.b	#1,d0                           	| [$800b: inc  a]
	jne	0f                                 	| [$800c: ret  z] a=$ff: no event: quit
	rts                                    	| [...] a=$ff: no event: quit
0:
	subq.b	#1,d0                           	| [$800d: dec  a]
	move.b	d0,d3                           	| [$800e: ld   d,a] save event value for later
	MAKE_HL	a0                             	| [$800f: ld   (hl),$ff] acknowledge event
	st.b	(a0)                      	| [...] acknowledge event
	addq.b	#1,d6                           	| [$8011: inc  l]
	MAKE_HL	a0                             	| [$8012: ld   e,(hl)] get event parameter
	move.b	(a0),d4                         	| [...] get event parameter
	MAKE_HL	a0                             	| [$8013: ld   (hl),$ff] acknowledge param
	st.b	(a0)                      	| [...] acknowledge param
	addq.b	#1,d6                           	| [$8015: inc  l]
	move.b	d6,d0                           	| [$8016: ld   a,l]
	cmp.b	#0x40,d0                         	| [$8017: cp   $40]
	jcs	l_801d                             	| [$8019: jr   c,$801d]
	move.b	#0x00,d6                        	| [$801b: ld   l,$00] wrap event pointer
l_801d:
	GET_ADDRESS	consumed_event_pointer_ed82,a0	| [$801d: ld   (consumed_event_pointer_ed82),hl]
	MAKE_HL_NO_AR                          	| [...]
	MOVE_W_FROM_REG	d6,a0                         	| [...]
	move.b	d4,d0                           	| [$8020: ld   a,e]
	GET_ADDRESS	0xed84,a0                  	| [$8021: ld   ($ed84),a]
	move.b	d0,(a0)                         	| [...]
	move.b	d3,d0                           	| [$8024: ld   a,d] restore a
	GET_ADDRESS	0xed85,a0                  	| [$8025: ld   ($ed85),a]
	move.b	d0,(a0)                         	| [...]
	.ifndef	RELEASE
	move.w	#15,d7
